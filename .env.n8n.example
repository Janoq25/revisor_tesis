# n8n database connection (Postgres container)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# n8n runtime
# Generate a strong, random key. If you change it later, stored credentials can't be decrypted.
N8N_ENCRYPTION_KEY=CHANGE_ME_32+_CHARS_RANDOM_HEX
WEBHOOK_URL=http://127.0.0.1:5678/
GENERIC_TIMEZONE=America/Lima
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_SECURE_COOKIE=false

# Callback hacia Next (desde dentro del contenedor n8n)
# En este proyecto (compose): http://frontend:3000/api/webhook-callback
FRONTEND_CALLBACK_URL=http://frontend:3000/api/webhook-callback

